# Home Paper Trainer - Environment Configuration
# 
# REQUIRED: These MUST be set in production
# Development defaults are in backend/config.py but MUST be overridden in production

# =============================================================================
# APPLICATION
# =============================================================================
APP_NAME=Home Paper Trainer
DEBUG=false

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection URL with asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://paper_trainer:paper_trainer@localhost:5432/paper_trainer

# =============================================================================
# SECURITY
# =============================================================================
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# CORS (Optional - overrides default local dev origins)
# =============================================================================
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost,http://localhost:8000,http://127.0.0.1

# =============================================================================
# API
# =============================================================================
API_V1_PREFIX=/api/v1
