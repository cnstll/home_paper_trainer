# Home Paper Trainer - Docker Environment Configuration
# Used for both local development (in containers) and production

# Database - PostgreSQL with asyncpg driver for SQLAlchemy async
DATABASE_URL=postgresql+asyncpg://paper_trainer:paper_trainer@db:5432/paper_trainer

# Application
APP_NAME=Home Paper Trainer
DEBUG=True
SECRET_KEY=change-me-in-production-for-security
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_V1_PREFIX=/api/v1

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://localhost:8000,http://127.0.0.1,http://127.0.0.1:8000

# Python path for imports
PYTHONPATH=/app
